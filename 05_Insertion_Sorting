n = int(input())
arr = list(map(int,input().split()))

for i in range(1, n ):

    key = arr[i]
    j = i - 1

    while j >= 0 and key < arr[j]:
        arr[j+ 1 ] = arr[j]
        j -= 1  # j = j - 1

    arr[j + 1 ] = key 
print(*arr)  # if we use function in our code then we use use return 
              # in this code we don't use function, so we write print
